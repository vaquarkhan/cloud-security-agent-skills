# Environment variables — NEVER commit real values.
# All secrets must come from cloud workload identity or platform bindings.

# Bastion policy path (default: ./bastion.yaml)
# BASTION_CONFIG=./bastion.yaml

# Path to skills/ (default: ./skills in repo root)
# SKILLS_PATH=./skills

# Cloud-specific (set by platform, not in source control)
# OCI_RESOURCE_PRINCIPAL_VERSION=
# TRUSTED_PROFILE_NAME=
# ALIBABA_CLOUD_ROLE_ARN=

# Alert webhooks (optional)
# BASTION_WEBHOOK_URL=
# SLACK_WEBHOOK_URL=
